{
  "name": "K7-extension",
  "description": "Extension adding a button on every youtube video to send the link to the desktop app K7-YTB-MP3.",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/Logo-16_16.png",
    "32": "icons/Logo-32_32.png",
    "48": "icons/Logo-48_48.png",
    "128": "icons/Logo-128_128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch?v=*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],"host_permissions": [
    "https://github.com/LorisVVV/K7-YTB-MP3/releases/"
  ],
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "scripting"
  ]
}